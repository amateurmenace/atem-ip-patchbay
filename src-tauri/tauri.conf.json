{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ATEM IP Patchbay",
  "version": "0.2.0-alpha.8",
  "identifier": "org.weirdmachine.atem-ip-patchbay",
  "build": {
    "frontendDist": "../webui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ATEM IP Patchbay",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "sidecar/*": "sidecar/",
      "../bmd_emulator/static/*": "static/"
    },
    "copyright": "Copyright (C) 2026 Stephen Walter",
    "category": "Video",
    "shortDescription": "Push any video source into ATEM gear via BMD-flavored SRT",
    "longDescription": "Cross-platform proof-of-concept that pushes NDI / SDI / HDMI / non-Blackmagic SRT or RTMP video sources into Blackmagic ATEM switchers, Streaming Decoders, and Streaming Bridges over the BMD-flavored SRT handshake.",
    "macOS": {
      "signingIdentity": "Developer ID Application: Stephen Walter (6M536MV7GT)",
      "minimumSystemVersion": "11.0",
      "entitlements": null,
      "infoPlist": "Info.plist",
      "frameworks": [
        "/usr/local/lib/libndi.dylib"
      ]
    }
  }
}
